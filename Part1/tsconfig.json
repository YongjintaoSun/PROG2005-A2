{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "outDir": "./js",
    "rootDir": "./js",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0"
  },
  "include": ["js/**/*.ts"],
  "exclude": ["node_modules"]
}
